# ─── Database ───────────────────────────────────────────────
# Use SQLite for local dev (default if DATABASE_URL is unset)
DATABASE_URL=sqlite:///./edubridge.db
# For PostgreSQL: DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edubridge

# ─── Security ───────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-in-production

# ─── AI APIs ────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyABHKnvugxs7vE9GoXDQ8IgAF8i40h4VJ4
OPENAI_API_KEY=your_openai_api_key_here   # optional

# ─── Email / SMTP (for OTP password reset) ──────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ─── App Settings ───────────────────────────────────────────
DEBUG=true
